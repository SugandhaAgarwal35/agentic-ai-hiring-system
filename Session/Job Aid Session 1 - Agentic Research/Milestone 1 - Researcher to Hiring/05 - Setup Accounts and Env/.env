# ==========================================================================
# Job Aid Session 1 — Milestone 1 provider keys
# Copy this file to `.env` (same folder) and fill in your 4 keys.
# `.env` is git-ignored. This .env.example is safe to commit.
# ==========================================================================

# --- Groq (Researcher #1, Skill Set, Hiring Process) -----------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google AI Studio / Gemini (Researcher #2) -----------------------------
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash-lite

# --- Cerebras (Researcher #3) ----------------------------------------------
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-8b

# --- OpenRouter (Consolidator) ---------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# --- LangSmith tracing (enabled in Milestone 2; keep blank for now) --------
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=job-aid-session-1
LANGCHAIN_TRACING_V2=false

# ETL_WRITE_MODE=db
ETL_WRITE_MODE=

DATABASE_URL=